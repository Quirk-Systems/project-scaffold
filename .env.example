# ============================================================
# Environment Variables Template
# Copy to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.
# Use 1Password CLI: op inject -i .env.example -o .env.local
# ============================================================

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp_dev
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp_test

# Auth
NEXTAUTH_SECRET=change-me-min-32-chars-random-string
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=change-me-min-32-chars-random-string

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_price_id

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Email (Resend)
RESEND_API_KEY=re_your_key_here
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Your App

# AI
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_key_here

# Storage (Cloudflare R2 / AWS S3)
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Monitoring
SENTRY_DSN=https://your-dsn@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Background Jobs (Inngest)
INNGEST_EVENT_KEY=your_event_key
INNGEST_SIGNING_KEY=your_signing_key

# Feature Flags
NEXT_PUBLIC_FLAG_NEW_DASHBOARD=false
NEXT_PUBLIC_FLAG_AI_CHAT=false
